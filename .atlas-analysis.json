  "keyFeatures": [
    "Resource-based architecture with convention over configuration",
    "Auto-generated database services from Zod schemas",
    "Event-driven handlers that react to database changes",
    "Automatic syncing of embedded document references",
    "AI-native development with Cursor commands",
    "Built-in auth, real-time, queues, and scheduler",
    "CLI for scaffolding and deployment"
  ],
  "publicApiSurface": [
    "hive init - Initialize new project",
    "hive run - Start development server",
    "hive prepare - Build for production",
    "hive deploy - Deploy to Hive Cloud",
    "hive install - Install plugins",
    "db.services.{resource} - Auto-generated database services",
    "add-resource - AI command to create resources",
    "add-endpoint - AI command to create endpoints",
    "add-handler - AI command to create event handlers",
    "add-middleware - AI command to create middlewares",
    "add-service - AI command to create services",
    "add-scheduler - AI command to create cron jobs"
